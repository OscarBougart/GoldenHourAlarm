{
  "expo": {
    "name": "Golden Hour Alarm",
    "slug": "GoldenHourAlarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "goldenhouralarm",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#C05A0A"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Golden Hour Alarm needs your location to calculate golden and blue hour times for your exact position.",
        "NSLocationAlwaysUsageDescription": "Golden Hour Alarm uses your location to calculate golden and blue hour times."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E1117"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Golden Hour Alarm needs your location to calculate golden and blue hour times."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/.gitkeep",
          "color": "#F5A623",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
